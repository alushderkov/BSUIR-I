<Window x:Class="DMMaA_LAB_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DMMaA_LAB_3"
        mc:Ignorable="d"
        Title="DMMaA LAB 3" Height="600" Width="1200" MinHeight="600" MinWidth="1200"
        Background="#FF2D2D30" Foreground="White">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="2*" />
			<!-- График займет больше места -->
			<ColumnDefinition Width="1*" />
			<!-- Настройки и результаты -->
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- График -->
		<Border Name="BorderImage" Grid.Column="0" Grid.RowSpan="2"
                BorderBrush="LightGray" BorderThickness="3">
			<Image Name="Canvas" />
		</Border>

		<!-- Настройки -->
		<Border Grid.Column="1" Grid.Row="0" BorderBrush="LightGray" BorderThickness="3" Margin="5">
			<StackPanel Orientation="Vertical" VerticalAlignment="Center">
				<TextBlock FontSize="15" TextAlignment="Center" FontFamily="Open Sans" Margin="6">
					P(C1)
				</TextBlock>
				<Slider Name="SliderPC1" Margin="5"
                        Minimum="0" Maximum="1" SmallChange="0.0000000001" Value="0.5" TickPlacement="BottomRight" />
				<TextBlock Margin="5" Text="{Binding ElementName=SliderPC1, Path=Value}" />

				<TextBlock FontSize="15" TextAlignment="Center" FontFamily="Open Sans" Margin="6">
					P(C2)
				</TextBlock>
				<Slider Name="SliderPC2" Margin="5"
                        Minimum="0" Maximum="1" SmallChange="0.0000000001" Value="0.5" TickPlacement="BottomRight" />
				<TextBlock Margin="5" Text="{Binding ElementName=SliderPC2, Path=Value}" />
			</StackPanel>
		</Border>

		<!-- Результаты -->
		<Border Grid.Column="1" Grid.Row="1" BorderBrush="LightGray" BorderThickness="3" Margin="5">
			<StackPanel Orientation="Vertical" VerticalAlignment="Center">
				<TextBlock FontSize="20" TextAlignment="Center" FontFamily="Open Sans" Margin="6">
					Результаты
				</TextBlock>
				<TextBlock Name="FalseAlarm" Margin="8" FontFamily="Open Sans" FontSize="15"
                           TextAlignment="Center">
					Вероятность ложной тревоги
				</TextBlock>
				<TextBox IsEnabled="False" Name="TextBoxFalseAlarm" TextAlignment="Center"
                         VerticalAlignment="Center" FontSize="15" Margin="5">
					Placeholder
				</TextBox>
				<TextBlock Name="Miss" Margin="8" FontFamily="Open Sans" FontSize="15"
                           TextAlignment="Center">
					Вероятность пропуска обнаружения
				</TextBlock>
				<TextBox IsEnabled="False" Name="TextBoxMiss" TextAlignment="Center"
                         VerticalAlignment="Center" FontSize="15" Margin="5">
					Placeholder
				</TextBox>
				<TextBlock Name="AmountOfRisk" Margin="8" FontFamily="Open Sans" FontSize="15"
                           TextAlignment="Center">
					Суммарная ошибка классификации
				</TextBlock>
				<TextBox IsEnabled="False" Name="TextBoxAmountOfRisk" TextAlignment="Center"
                         VerticalAlignment="Center" FontSize="15" Margin="5">
					Placeholder
				</TextBox>
			</StackPanel>
		</Border>
	</Grid>
</Window>
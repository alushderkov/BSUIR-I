<Window x:Class="DMMaA_LAB_4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DMMaA_LAB_4"
        mc:Ignorable="d"
        Title="DMMaA LAB 4" Height="600" Width="1200" MinHeight="600" MinWidth="1200"
        Background="#FF2D2D30" Foreground="White">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="2.5*" />
			<!-- Правая панель -->
			<ColumnDefinition Width="1.5*" />
			<!-- Левая панель -->
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="*" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- Правая панель (обучающая выборка и решающие функции) -->
		<Border Grid.Column="0" Grid.RowSpan="2" BorderBrush="LightGray" BorderThickness="3" Margin="5">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*" />
					<ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>

				<!-- Заголовки -->
				<Border Grid.Column="0" Grid.Row="0" BorderBrush="LightGray" BorderThickness="3" Margin="5">
					<TextBlock FontSize="20" TextAlignment="Center" FontFamily="Open Sans" Margin="10">
						Обучающая выборка
					</TextBlock>
				</Border>

				<Border Grid.Column="1" Grid.Row="0" BorderBrush="LightGray" BorderThickness="3" Margin="5">
					<TextBlock FontSize="20" TextAlignment="Center" FontFamily="Open Sans" Margin="10">
						Решающие функции
					</TextBlock>
				</Border>

				<!-- Списки -->
				<Border Grid.Column="0" Grid.Row="1" BorderBrush="LightGray" BorderThickness="3" Margin="5">
					<ListView Name="ListViewSelection" />
				</Border>

				<Border Grid.Column="1" Grid.Row="1" BorderBrush="LightGray" BorderThickness="3" Margin="5">
					<ListView Name="ListViewSoultions" />
				</Border>
			</Grid>
		</Border>

		<!-- Левая панель (настройки и классификация) -->
		<Border Grid.Column="1" Grid.RowSpan="2" BorderBrush="LightGray" BorderThickness="3" Margin="5">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<!-- Настройки -->
				<StackPanel Grid.Row="0" Margin="10">
					<TextBlock FontSize="17" TextAlignment="Center" FontFamily="Open Sans" Margin="0,0,0,10">
						Количество классов
					</TextBlock>
					<Slider Name="SliderClassesNumber" IsSnapToTickEnabled="True" Margin="5"
                            Minimum="1" Maximum="10" SmallChange="1" Value="1" TickPlacement="BottomRight" />
					<TextBlock FontSize="14" FontFamily="Open Sans" TextAlignment="Center"
                               Text="{Binding ElementName=SliderClassesNumber, Path=Value}" />
				</StackPanel>

				<StackPanel Grid.Row="1" Margin="10">
					<TextBlock FontSize="17" TextAlignment="Center" FontFamily="Open Sans" Margin="0,0,0,10">
						Количество объектов в классе
					</TextBlock>
					<Slider Name="SliderObjectNumber" IsSnapToTickEnabled="True" Margin="5"
                            Minimum="1" Maximum="100" SmallChange="1" Value="1" TickPlacement="BottomRight" />
					<TextBlock FontSize="14" FontFamily="Open Sans" TextAlignment="Center"
                               Text="{Binding ElementName=SliderObjectNumber, Path=Value}" />
				</StackPanel>

				<StackPanel Grid.Row="2" Margin="10">
					<TextBlock FontSize="17" TextAlignment="Center" FontFamily="Open Sans" Margin="0,0,0,10">
						Количество признаков объекта
					</TextBlock>
					<Slider Name="SliderAttributeNumber" IsSnapToTickEnabled="True" Margin="5"
                            Minimum="1" Maximum="100" SmallChange="1" Value="1" TickPlacement="BottomRight" />
					<TextBlock FontSize="14" FontFamily="Open Sans" TextAlignment="Center"
                               Text="{Binding ElementName=SliderAttributeNumber, Path=Value}" />
				</StackPanel>

				<Button Name="ButtonCreateSelection" Grid.Row="3" Margin="10"
                        FontFamily="Open Sans" FontSize="15" Padding="10"
                        Click="ButtonCreateSelection_Click">
					Создать обучающую выборку
				</Button>

				<!-- Классификация -->
				<Border Grid.Row="4" BorderBrush="LightGray" BorderThickness="0,3,0,0" Margin="10">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<TextBlock FontSize="17" TextAlignment="Center" FontFamily="Open Sans" Margin="0,0,0,10">
							Классификация
						</TextBlock>

						<ScrollViewer Grid.Row="1">
							<StackPanel Name="inputPanel" />
						</ScrollViewer>

						<Button Name="ButtonClassify" Grid.Row="2" Margin="0,10,0,0"
                                FontFamily="Open Sans" FontSize="15" Padding="10"
                                Click="ButtonClassify_Click">
							Классифицировать
						</Button>
					</Grid>
				</Border>
			</Grid>
		</Border>
	</Grid>
</Window>